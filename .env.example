# Copy to .env and fill in. Used by docker-compose and local runs.

# OpenAI-compatible inference endpoint (e.g. local llama-swap).
LLM_ENDPOINT=http://jason-server:11436/v1
LLM_API_KEY=unused
# A thinking + tool-calling model so the chat shows reasoning + tool blocks.
ORCH_MODEL=qwen3.6-35b
# Model the web-researcher agent runs on (tool-calling capable).
RESEARCHER_MODEL=qwen3.6-35b
# Independent judge model for the trust gate. Best as a separate model (the
# milestone names selene-mini); falls back to the researcher model for local dev.
# Leave empty to disable adversarial vetting entirely.
JUDGE_MODEL=qwen3.6-35b

# The web-researcher's tool backends (keyless). Defaults point at the compose
# services; override to use existing instances (e.g. on a home server).
SEARXNG_URL=http://searxng:8080
CRAWL4AI_URL=http://crawl4ai:11235

# Postgres DSN for the relational store.
# In docker-compose the host is `db`; for a bare local run use localhost.
DATABASE_URL=postgres://quack:quack@localhost:5432/quack?sslmode=disable

# Long-term memory (M4). Leave QDRANT_URL and EMBEDDING_MODEL empty to disable
# memory entirely (the app still builds and runs); when set, both are required.
# In docker-compose the host is `qdrant`; for a bare local run use localhost.
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
# Embedding model. Served by the same llama-swap as LLM_ENDPOINT (selected by
# name); qwen3-embed is a resident model there. Empty disables memory.
EMBEDDING_MODEL=qwen3-embed
