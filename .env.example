# Copy to .env and fill in. Used by docker-compose and local runs.

# OpenAI-compatible inference endpoint (e.g. local llama-swap).
LLM_ENDPOINT=http://jason-server:11436/v1
LLM_API_KEY=unused
# A thinking + tool-calling model so the chat shows reasoning + tool blocks.
ORCH_MODEL=qwen3.6-35b

# Postgres DSN for the relational store.
# In docker-compose the host is `db`; for a bare local run use localhost.
DATABASE_URL=postgres://quack:quack@localhost:5432/quack?sslmode=disable
